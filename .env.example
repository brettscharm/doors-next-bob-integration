# DOORS Next MCP Server Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit the .env file to git!

# =============================================================================
# REQUIRED: DOORS Next Server Configuration
# =============================================================================

# Your DOORS Next server URL
# This should be the base URL ending in /rm
# Example: https://your-doors-server.com/rm
DOORS_URL=https://your-doors-server.com/rm

# Your DOORS Next username
# This is your IBM ID or DOORS username
DOORS_USERNAME=your_username

# Your DOORS Next password
# This is your IBM ID password or DOORS password
DOORS_PASSWORD=your_password

# =============================================================================
# OPTIONAL: Default Project (not required for MCP server)
# =============================================================================

# Default project name (optional - MCP server can query any project)
# Only needed if you're using doors_client.py directly
DOORS_PROJECT=Your Project Name

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env and replace the placeholder values with your actual credentials
#
# 3. Make sure .env is in .gitignore (it should be by default)
#
# 4. Test your connection:
#    python3 -c "from doors_client import DOORSNextClient; c = DOORSNextClient.from_env(); print('✅ Connected!' if c.authenticate() else '❌ Failed')"
#
# =============================================================================